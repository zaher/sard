// PASS03.sard - Unicode Identifiers
// ASCII identifiers
foo = 1
my_var = 2
CamelCase = 3
camelcase = 4  // same as CamelCase (case insensitive)
_underscore = 5
_private = 6  // convention: leading underscore

// Unicode identifiers
manana = 7     // ñ - Spanish
chinese = 8    // 你好
japanese = 9   // こんにちは
greek = 10     // Φυσική

// Unicode with combining marks
combined = 11   // e.g., n + combining tilde
