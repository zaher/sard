// PASS03.sard - Unicode Identifiers
// ASCII identifiers
foo = 1
my_var = 2
CamelCase = 3
camelcase = 4  // same as CamelCase (case insensitive)
_underscore = 5
_private = 6  // convention: leading underscore

// Unicode identifiers
ñ = 7     // ñ - Spanish
你好 = 8    // 你好
こんにちは = 9   // こんにちは
Φυσική = 10     // Φυσική
