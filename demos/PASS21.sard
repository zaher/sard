// Bloacks Declaration
foo1 : { x = 1 }  // This is parsed as callable declaration

// To make a variable with block value, use = assignment:
foo2 = { x = 1 }  // This is correct - block executes immediately

// Trying to declare type with block (callable declaration)
// data : type { x = 1 }  // TODO This declares callable named 'data', not variable