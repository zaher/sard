// Invalid Array Operations
// ERROR: Index out of bounds (runtime error, not syntax error)
arr = [1, 2, 3]
// val = arr[100]  // Runtime error: index 100 out of bounds

// ERROR: Compound assignment on non-existent element
// arr[10] += 5   // May be runtime error depending on implementation

// ERROR: Accessing undefined variable as array
// x[0] = 5       // Runtime error: x is not an array

// ERROR: Trying to call array
// arr()          // Runtime error: array not callable
