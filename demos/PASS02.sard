// Escape Sequences and String Concatenation
// Standalone escape sequences (outside string literals)
new_line = \n
greeting = "Hello" \n "World"
path = "C:" \\ "Users" \\ "test"
tabbed = "col1" \t "col2" \t "col3"
multi = "line1" \n "line2" \r\n "line3"

// Multiple escapes
complex = "start" \n\n\n "end"

// Mixed with no spaces
compact = "A"\n"B"\t"C"

// Escapes at different positions
prefix = \n "starts with newline"
suffix = "ends with newline" \n
