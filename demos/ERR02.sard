// Invalid String/Escape Sequences
// ERROR: Missing closing quote
unterminated = "Hello, World!

// There is no escape sequence inside string (escape must be outside)
wrong = "Hello\nWorld"  // Not an escape inside string, it is full string

// ERROR: Invalid escape character
invalid = "test" \x "more"  // \x is not a valid escape

// NOT ERROR: Standalone escape without adjacent string treated as string
standalone = \n  // Treated string literals
