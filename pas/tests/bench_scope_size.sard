// Measure cost of one extra member in scope - if TStringList is linear,
// a scope with N members makes each lookup O(N).
start = clock()
x = 0
loop(1000000) {
    x + 1
}
elapsed = clock() - start
print("baseline ident 1M: ", elapsed, "ms")

// Now add 20 members to root scope and re-measure
a1 = 1
a2 = 2
a3 = 3
a4 = 4
a5 = 5
a6 = 6
a7 = 7
a8 = 8
a9 = 9
a10 = 10
a11 = 11
a12 = 12
a13 = 13
a14 = 14
a15 = 15
a16 = 16
a17 = 17
a18 = 18
a19 = 19
a20 = 20

start = clock()
loop(1000000) {
    x + 1
}
elapsed = clock() - start
print("with 20 members 1M: ", elapsed, "ms")
